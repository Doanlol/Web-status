# =============================================================
# DevOps Status Dashboard - Next.js Environment Variables
# =============================================================
# Sao chép file này thành .env.local và điền thông tin thực:
#   cp .env.local.example .env.local
#
# Lấy các giá trị từ: Supabase Dashboard > Settings > API
# =============================================================

# URL project Supabase của bạn
NEXT_PUBLIC_SUPABASE_URL=https://<YOUR_PROJECT_REF>.supabase.co

# Anon Key (public key, an toàn để dùng phía client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
