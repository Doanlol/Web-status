# =============================================================
# DevOps Status Dashboard - Agent Environment Variables
# =============================================================
# Sao chép file này thành .env và điền thông tin thực:
#   cp .env.example .env
# =============================================================

# URL project Supabase của bạn (lấy từ Settings > API)
SUPABASE_URL=https://<YOUR_PROJECT_REF>.supabase.co

# Service Role Key (lấy từ Settings > API > service_role key)
# CẢNH BÁO: Không commit key này lên Git!
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SERVICE_ROLE_KEY>

# UUID của server (tạo thủ công trong bảng servers trên Supabase)
SERVER_ID=<UUID_OF_YOUR_SERVER>

# Khoảng thời gian giữa các lần gửi metrics (giây, mặc định: 10)
SEND_INTERVAL=10

# Ngưỡng CPU để gửi cảnh báo (%, mặc định: 80)
CPU_ALERT_THRESHOLD=80
